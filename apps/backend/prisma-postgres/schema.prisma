generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  passwordHash           String
  role                   String                  @default("PLAYER")
  status                 String                  @default("ACTIVE")
  bannedAt               DateTime?
  bannedUntil            DateTime?
  banReason              String?
  termsAcceptedAt        DateTime?
  emailVerifiedAt        DateTime?
  mustChangePassword     Boolean                 @default(false)
  passwordResetAt        DateTime?
  temporaryPasswordUsed  Boolean                 @default(false)
  lastPasswordChangeAt   DateTime                @default(now())
  trustStatus            String                  @default("NORMAL")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  profile                UserProfile?
  wallet                 Wallet?
  subscription           Subscription?
  dailyClaim             DailyRewardClaim?
  ownedSkins             OwnedSkin[]
  scores                 Score[]
  purchases              PurchaseTransaction[]
  walletTransactions     WalletTransaction[]
  sessions               GameSession[]
  rouletteSpins          RouletteSpin[]
  adRewards              AdReward[]
  extraLifeUses          ExtraLifeUsage[]
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationCodes EmailVerificationCode[]
  adminActions           ModerationAction[]      @relation("AdminModerationActions")
  receivedActions        ModerationAction[]      @relation("TargetModerationActions")
  supportTickets         SupportTicket[]         @relation("UserSupportTickets")
  answeredSupportTickets SupportTicket[]         @relation("AdminSupportTickets")
  scoreReviews           Score[]                 @relation("ScoreReviewer")
  restrictions           Restriction[]           @relation("RestrictedUser")
  issuedRestrictions     Restriction[]           @relation("RestrictionAdmin")
  adminAuditLogs         AdminAuditLog[]         @relation("AuditAdmin")
  targetedAuditLogs      AdminAuditLog[]         @relation("AuditTargetUser")
  guestTransferAttempts  GuestTransferAttempt[]
  ownedThemes            OwnedTheme[]
  analyticsEvents        AnalyticsEvent[]
  achievements           AchievementProgress[]
  dailyMissions          DailyMissionProgress[]
  seasonProgress         SeasonProgress?
}

model UserProfile {
  id                        String    @id @default(uuid())
  userId                    String    @unique
  displayName               String
  locale                    String    @default("en")
  avatarUrl                 String?
  highScore                 Int       @default(0)
  selectedArrowSkinId       String?
  selectedTrailSkinId       String?
  lastDailyRewardAt         DateTime?
  dailyRewardStreak         Int       @default(0)
  selectedThemeId           String    @default("classic-neon")
  customizationJson         String    @default("{}")
  gameSettingsJson          String    @default("{}")
  showUsernameInLeaderboard Boolean   @default(true)
  hideProfile               Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id              String              @id @default(uuid())
  userId          String              @unique
  coins           Int                 @default(0)
  gems            Int                 @default(0)
  rouletteTickets Int                 @default(0)
  extraLives      Int                 @default(0)
  lifetimeCoins   Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    WalletTransaction[]
  rouletteSpins   RouletteSpin[]
  adRewards       AdReward[]
  extraLifeUses   ExtraLifeUsage[]
}

model Skin {
  id             String                @id @default(uuid())
  slug           String                @unique
  nameKey        String
  descriptionKey String
  category       String
  rarity         String
  priceCoins     Int                   @default(0)
  priceGems      Int                   @default(0)
  isPremium      Boolean               @default(false)
  isLimited      Boolean               @default(false)
  active         Boolean               @default(true)
  visualJson     String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  ownedBy        OwnedSkin[]
  purchases      PurchaseTransaction[]
  rouletteWins   RouletteSpin[]
}

model OwnedSkin {
  id      String   @id @default(uuid())
  userId  String
  skinId  String
  ownedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skin    Skin     @relation(fields: [skinId], references: [id], onDelete: Cascade)

  @@unique([userId, skinId])
  @@index([userId])
}

model Score {
  id           String    @id @default(uuid())
  userId       String
  sessionId    String?
  score        Int
  distance     Int
  durationMs   Int
  status       String    @default("valid")
  reviewReason String?
  reviewedAt   DateTime?
  reviewedById String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy   User?     @relation("ScoreReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([score])
  @@index([createdAt])
  @@index([status])
}

model PurchaseTransaction {
  id               String   @id @default(uuid())
  userId           String
  skinId           String?
  provider         String
  type             String   @default("skin")
  status           String   @default("pending")
  amountCoins      Int      @default(0)
  amountGems       Int      @default(0)
  amountTickets    Int      @default(0)
  amountExtraLives Int      @default(0)
  idempotencyKey    String?  @unique
  metadata         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skin             Skin?    @relation(fields: [skinId], references: [id])

  @@index([userId])
  @@index([provider])
  @@index([type])
  @@index([status])
}

model WalletTransaction {
  id               String   @id @default(uuid())
  userId           String
  walletId         String
  type             String
  provider         String
  amountCoins      Int      @default(0)
  amountGems       Int      @default(0)
  amountTickets    Int      @default(0)
  amountExtraLives Int      @default(0)
  metadata         String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet           Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([walletId])
}

model RouletteSpin {
  id           String   @id @default(uuid())
  userId       String
  walletId     String
  rewardType   String
  rewardAmount Int      @default(0)
  rewardSkinId String?
  rarity       String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  rewardSkin   Skin?    @relation(fields: [rewardSkinId], references: [id])
}

model AdReward {
  id           String   @id @default(uuid())
  userId       String
  walletId     String
  provider     String
  rewardType   String
  rewardAmount Int      @default(0)
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model ExtraLifeUsage {
  id       String   @id @default(uuid())
  userId   String
  walletId String
  usedAt   DateTime @default(now())
  reason   String
  runId    String?
  amount   Int      @default(1)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet   Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                String    @id @default(uuid())
  userId            String    @unique
  status            String    @default("free")
  plan              String    @default("standard")
  provider          String?
  startDate         DateTime?
  endDate           DateTime?
  cancelAtPeriodEnd Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyRewardClaim {
  id          String    @id @default(uuid())
  userId      String    @unique
  lastClaimAt DateTime?
  streak      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OfferBundle {
  id              String   @id @default(uuid())
  slug            String   @unique
  titleKey        String
  descriptionKey  String
  priceCoins      Int      @default(0)
  priceGems       Int      @default(0)
  coins           Int      @default(0)
  gems            Int      @default(0)
  tickets         Int      @default(0)
  extraLives      Int      @default(0)
  discountPercent Int      @default(0)
  featured        Boolean  @default(false)
  premiumOnly     Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GameSession {
  id             String    @id @default(uuid())
  userId         String
  seed           String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  score          Int       @default(0)
  coinsCollected Int       @default(0)
  distance       Int       @default(0)
  durationMs     Int       @default(0)
  obstacleHits   Int       @default(0)
  checksum       String?
  valid          Boolean   @default(false)
  antiCheatNotes String?
  status         String    @default("started")
  checkpointCount        Int       @default(0)
  lastCheckpointAt       DateTime?
  lastCheckpointElapsedMs Int      @default(0)
  checkpointDistance     Int       @default(0)
  checkpointCoins        Int       @default(0)
  checkpointTransitions  Int       @default(0)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startedAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationCode {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ModerationAction {
  id           String   @id @default(uuid())
  adminId      String?
  targetUserId String
  action       String
  reason       String?
  message      String?
  createdAt    DateTime @default(now())
  admin        User?    @relation("AdminModerationActions", fields: [adminId], references: [id], onDelete: SetNull)
  targetUser   User     @relation("TargetModerationActions", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetUserId])
  @@index([action])
}

model SupportTicket {
  id              String    @id @default(uuid())
  userId          String?
  adminId         String?
  contactEmail    String?
  contactName     String?
  category        String
  subject         String
  message         String
  status          String    @default("OPEN")
  adminResponse   String?
  relatedEntityId String?
  internalNote    String?
  appealStatus    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  closedAt        DateTime?
  user            User?     @relation("UserSupportTickets", fields: [userId], references: [id], onDelete: SetNull)
  admin           User?     @relation("AdminSupportTickets", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([adminId])
  @@index([status])
  @@index([createdAt])
}

model OwnedTheme {
  id      String   @id @default(uuid())
  userId  String
  themeId String
  source  String   @default("unlock")
  ownedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, themeId])
  @@index([userId])
}

model Restriction {
  id        String    @id @default(uuid())
  userId    String
  adminId   String?
  type      String
  reason    String
  notes     String?
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation("RestrictedUser", fields: [userId], references: [id], onDelete: Cascade)
  admin     User?     @relation("RestrictionAdmin", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([userId, active])
  @@index([type])
}

model AdminAuditLog {
  id             String   @id @default(uuid())
  adminId        String?
  actionType     String
  targetUserId   String?
  targetEntityId String?
  reason         String?
  metadata       String?
  createdAt      DateTime @default(now())
  admin          User?    @relation("AuditAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  targetUser     User?    @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([targetUserId])
  @@index([actionType])
  @@index([createdAt])
}

model GuestTransferAttempt {
  id               String   @id @default(uuid())
  userId           String
  guestIdHash      String   @unique
  status           String
  bestScore        Int      @default(0)
  transferredScore Int      @default(0)
  reason           String?
  metadata         String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AnalyticsEvent {
  id          String   @id @default(uuid())
  userId      String?
  guestIdHash String?
  eventType   String
  sessionKey  String?
  metadata    String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@index([guestIdHash, createdAt])
}

model AchievementProgress {
  id            String    @id @default(uuid())
  userId        String
  achievementId String
  progress      Int       @default(0)
  unlockedAt    DateTime?
  claimedAt     DateTime?
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model DailyMissionProgress {
  id          String    @id @default(uuid())
  userId      String
  missionId   String
  dayKey      String
  progress    Int       @default(0)
  target      Int
  completedAt DateTime?
  claimedAt   DateTime?
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId, dayKey])
  @@index([userId, dayKey])
}

model SeasonProgress {
  id        String   @id @default(uuid())
  userId    String   @unique
  seasonId  String
  xp        Int      @default(0)
  level     Int      @default(1)
  premium   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
