{
  "name": "@waves/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "build:backend:prod": "npm run build:prod",
    "build:prod": "npm run build --workspace @waves/shared && prisma generate --schema prisma-postgres/schema.prisma && tsc -p tsconfig.json",
    "start": "node dist/apps/backend/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test --test-concurrency=1 src/utils/displayName.test.ts src/services/antiCheatService.test.ts src/app.integration.test.ts src/shopPurchaseConcurrency.test.ts",
    "db:generate": "prisma generate",
    "db:generate:prod": "prisma generate --schema prisma-postgres/schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy --schema prisma-postgres/schema.prisma",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@waves/shared": "0.1.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.19.21",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
